# Скопируйте в .env в корне репозитория (рядом с docker-compose.vps.yml).
# Для доступа с других машин подставьте публичный IP или домен так же, как в браузере.

# --- Рекомендуется сменить ---
POSTGRES_PASSWORD=смените_на_длинный_случайный

# URL API для браузера (не http://api:4000). После смены — пересобрать web: docker compose ... build web --no-cache
NEXT_PUBLIC_API_URL=http://ВАШ_IP_ИЛИ_ДОМЕН:18081

# Стабильный ключ Server Actions (build web). Один раз: openssl rand -base64 32 — вставьте сюда и не меняйте между пересборками
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# CORS: origin сайта (через запятую)
WEB_ORIGINS=http://ВАШ_IP_ИЛИ_ДОМЕН:18080,http://127.0.0.1:18080

# AdminJS на API: http://ВАШ_IP_ИЛИ_ДОМЕН:18081/admin (логин/пароль — смените)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=...
# ADMIN_SESSION_SECRET=...   # лучше 32+ символов: openssl rand -hex 32
# Без кастомных React-компонентов в AdminJS оставьте true (compose задаёт по умолчанию).
# ADMIN_JS_SKIP_BUNDLE=true

# --- Порты на хосте (если 18080/18081 заняты — поменяйте) ---
VPS_WEB_PORT=18080
VPS_API_PORT=18081

# --- Опционально ---
# POSTGRES_USER=electrotech
# POSTGRES_DB=electrotech

# true = при каждом старте API очистить каталог и залить демо-данные заново (только для демо)
# CATALOG_DEMO_RESEED=false
