API_PORT=4000
DATABASE_URL=postgresql://electrotech:electrotech@localhost:5432/electrotech

# CORS: браузерный origin фронтов (через запятую)
WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# В production оставьте synchronize выключенным (NODE_ENV=production по умолчанию)
# TYPEORM_SYNC=false

# Лог SQL в консоль (опционально)
# TYPEORM_LOGGING=true

# AdminJS (http://localhost:4000/admin)
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=admin123
# Замените на длинную случайную строку в production
ADMIN_SESSION_SECRET=change-me-please

# Пересид каталога при старте (только dev): очищает таблицы и заливает моки
CATALOG_FORCE_SEED=true

# Демо на VPS (NODE_ENV=production): очистить каталог и снова залить моки. Опасно на бою.
# CATALOG_DEMO_RESEED=true
