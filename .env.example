# Copy to .env at repo root for local tooling (optional).
# Docker Compose loads variables from a .env file in the same directory as docker-compose.yml.

# PostgreSQL
POSTGRES_USER=electrotech
POSTGRES_PASSWORD=electrotech
POSTGRES_DB=electrotech
DATABASE_URL=postgresql://electrotech:electrotech@localhost:5432/electrotech

# Redis
REDIS_URL=redis://localhost:6379

# API (NestJS)
API_PORT=4000
NODE_ENV=development

# Next.js apps (used when running outside Docker).
# Для `pnpm dev` у web/supplier уже задано в apps/*/.env.development — дублировать не обязательно.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Опционально: хостовый IP вместо localhost, если заходите с другого устройства в сети
# NEXT_PUBLIC_API_URL=http://192.168.x.x:4000
